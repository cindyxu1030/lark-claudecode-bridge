# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARKSUITE_CLI_BRAND=lark
# Use LARKSUITE_CLI_BRAND=feishu for Feishu China.
# Optional explicit override:
# LARK_OPENAPI_BASE_URL=https://open.larksuite.com
# FEISHU_OPENAPI_BASE_URL=https://open.feishu.cn

# Claude 默认配置
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_CWD=~
SESSIONS_DIR=~/.lark-claude

# Shared project memory root for Agent Hub
PROJECTS_ROOT=~/projects
AGENT_HUB_ROOT=~/projects/_agent-hub

# Optional multi-bot routing overrides. Usually the visible names work:
# Codex bridge uses Codex; Claude bridge uses Claude, Claude Code.
# BOT_MENTION_OPEN_IDS=ou_xxx
# OTHER_BOT_MENTION_OPEN_IDS=ou_yyy

# Agent-to-agent discussion defaults
# COLLAB_COORDINATOR_AGENT=codex
# COLLAB_CLAUDE_MODEL=claude-sonnet-4-6
# COLLAB_CODEX_MODEL=gpt-5.4

# Optional: load a different env file. Useful when one clone runs both bots.
# LARK_BRIDGE_ENV_FILE=.env.claude

# 工具权限模式：bypassPermissions（跳过所有确认，推荐个人使用）
#              default（需要确认敏感操作）
PERMISSION_MODE=bypassPermissions

# （可选）Claude CLI 路径，留空则自动从 PATH 查找
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Codex bridge only:
# DEFAULT_MODEL=gpt-5.4
# SESSIONS_DIR=~/.lark-codex
# CODEX_HOME=~/.codex
# CODEX_CLI_PATH=/Applications/Codex.app/Contents/Resources/codex
